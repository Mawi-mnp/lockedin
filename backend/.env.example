# Railway Configuration
# PostgreSQL will be auto-provisioned by Railway

# Database (Railway provides these automatically)
DATABASE_URL=postgresql://postgres:${{POSTGRES_PASSWORD}}@postgres.railway.internal:5432/railway

# Security
SECRET_KEY=${{SECRET_KEY}}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Stripe (optional - add later)
STRIPE_SECRET_KEY=${{STRIPE_SECRET_KEY}}
STRIPE_WEBHOOK_SECRET=${{STRIPE_WEBHOOK_SECRET}}

# CORS
FRONTEND_URL=https://commitment-score.vercel.app
